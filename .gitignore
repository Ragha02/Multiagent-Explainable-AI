# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg
.eggs/
*.whl

# ── Virtual environments ───────────────────────────────────────────────────────
venv/
.venv/
env/
ENV/
.env/

# ── Data — large CSVs regenerated via scripts/download_datasets.py ────────────
data/*.csv
data/*.json
data/geo/

# ── Generated pipeline outputs — regenerated by running the pipeline ──────────
ma_xai_outputs/*.png
ma_xai_outputs/*.jpg
ma_xai_outputs/*.jpeg

# ── IDE & editor files ─────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# ── macOS ──────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── Kaggle credentials ─────────────────────────────────────────────────────────
kaggle.json
.kaggle/

# ── Jupyter ────────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Logs ───────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Frontend — handled by frontend/.gitignore but mirrored here ───────────────
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/.env*
frontend/tsconfig.tsbuildinfo
frontend/AGENTS.md
frontend/CLAUDE.md

# ── Secrets ────────────────────────────────────────────────────────────────────
*.pem
*.key
.env
.env.local
.env.*.local
